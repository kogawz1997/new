# Discord Bot
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here
DISCORD_GUILD_ID=your_guild_id_here

# SCUM Webhook Server (bot side)
SCUM_WEBHOOK_PORT=3100
SCUM_WEBHOOK_SECRET=put_a_strong_random_secret_here
SCUM_WEBHOOK_MAX_BODY_BYTES=65536
SCUM_WEBHOOK_REQUEST_TIMEOUT_MS=10000

# SCUM Log Watcher (tail SCUM.log and send to webhook)
# Windows path must escape backslash, e.g. D:\\SCUMServer\\SCUM.log
SCUM_LOG_PATH=D:\\SCUMServer\\SCUM.log
# If watcher runs on same machine as bot, usually no change needed
SCUM_WEBHOOK_URL=http://127.0.0.1:3100/scum-event

# Watcher tuning (optional)
SCUM_WATCH_INTERVAL_MS=800
SCUM_WEBHOOK_TIMEOUT_MS=7000
SCUM_WEBHOOK_MAX_RETRIES=2
SCUM_WEBHOOK_RETRY_DELAY_MS=900
SCUM_EVENT_DEDUP_WINDOW_MS=2000
SCUM_EVENT_DEDUPE_TRACK_SIZE=5000
SCUM_EVENT_QUEUE_MAX=2000
SCUM_DEAD_LETTER_LOG_PATH=logs/scum-watcher-dead-letter.log
SCUM_WEBHOOK_ERROR_ALERT_WINDOW_MS=300000
SCUM_WEBHOOK_ERROR_ALERT_MIN_ATTEMPTS=10
SCUM_WEBHOOK_ERROR_ALERT_THRESHOLD=0.3
SCUM_QUEUE_ALERT_THRESHOLD=1500
SCUM_ALERT_COOLDOWN_MS=60000

# Item icon index (shop/purchase displays)
SCUM_ITEMS_INDEX_PATH=./scum_items-main/index.json
SCUM_ITEMS_DIR_PATH=./scum_items-main
SCUM_ITEMS_BASE_URL=https://vbothost.github.io/scum_items/

# Admin Web Dashboard
# Login:
# - runtime checks users from DB table: admin_web_users
# - first startup will bootstrap users from:
#   1) ADMIN_WEB_USERS_JSON (if provided), or
#   2) ADMIN_WEB_USER + ADMIN_WEB_PASSWORD
# - if ADMIN_WEB_PASSWORD is empty, password falls back to ADMIN_WEB_TOKEN
# - if both are empty, system generates temporary token/password at startup
ADMIN_WEB_HOST=127.0.0.1
ADMIN_WEB_PORT=3200
ADMIN_WEB_USER=admin
ADMIN_WEB_PASSWORD=
# Optional JSON bootstrap (first startup / table empty use case):
# ADMIN_WEB_USERS_JSON=[{"username":"owner","password":"StrongPass123!","role":"owner"},{"username":"mod1","password":"StrongPass456!","role":"mod"}]
ADMIN_WEB_SESSION_TTL_HOURS=12
ADMIN_WEB_SECURE_COOKIE=false
ADMIN_WEB_HSTS_ENABLED=false
ADMIN_WEB_HSTS_MAX_AGE_SEC=31536000
ADMIN_WEB_TOKEN=
ADMIN_WEB_MAX_BODY_BYTES=1048576
ADMIN_WEB_TRUST_PROXY=false
ADMIN_WEB_ALLOW_TOKEN_QUERY=false
ADMIN_WEB_ENFORCE_ORIGIN_CHECK=true
# Multiple origins via comma, e.g. http://127.0.0.1:3200,https://admin.example.com
ADMIN_WEB_ALLOWED_ORIGINS=
ADMIN_WEB_LOGIN_WINDOW_MS=60000
ADMIN_WEB_LOGIN_MAX_ATTEMPTS=8
ADMIN_WEB_LOGIN_SPIKE_WINDOW_MS=300000
ADMIN_WEB_LOGIN_SPIKE_THRESHOLD=10
ADMIN_WEB_LOGIN_SPIKE_IP_THRESHOLD=5
ADMIN_WEB_LOGIN_SPIKE_ALERT_COOLDOWN_MS=60000

# Optional: persistent data directory (default ./data)
#BOT_DATA_DIR=Z:\\scum-bot-data

# Database (Prisma + SQLite)
DATABASE_URL="file:./prisma/dev.db"
# Enforce DB-only persistence (recommended true in production after P2 migration)
PERSIST_REQUIRE_DB=false

# Auto delivery via RCON queue
RCON_HOST=127.0.0.1
RCON_PORT=27015
RCON_PASSWORD=
# Example:
# RCON_EXEC_TEMPLATE=mcrcon -H {host} -P {port} -p "{password}" "{command}"
RCON_EXEC_TEMPLATE=
DELIVERY_METRICS_WINDOW_MS=300000
DELIVERY_FAIL_RATE_ALERT_THRESHOLD=0.3
DELIVERY_FAIL_RATE_ALERT_MIN_SAMPLES=10
DELIVERY_QUEUE_ALERT_THRESHOLD=25
DELIVERY_ALERT_COOLDOWN_MS=60000
DELIVERY_QUEUE_STUCK_SLA_MS=120000
DELIVERY_IDEMPOTENCY_SUCCESS_WINDOW_MS=43200000

# Production startup guard:
# - If NODE_ENV=production, bot refuses to start when security baseline is weak.
# - Generate fresh secrets quickly:
#   npm run security:generate-secrets

# Runtime split flags (Phase 3: bot/web/worker separation)
# Bot process toggles:
# - Keep true for legacy single-process mode.
# - Set admin/rentbike/delivery=false when running dedicated worker + standalone web.
BOT_ENABLE_SCUM_WEBHOOK=true
BOT_ENABLE_RESTART_SCHEDULER=true
BOT_ENABLE_ADMIN_WEB=true
BOT_ENABLE_RENTBIKE_SERVICE=true
BOT_ENABLE_DELIVERY_WORKER=true
BOT_ENABLE_OPS_ALERT_ROUTE=true

# Dedicated worker toggles (used by `npm run start:worker`)
WORKER_ENABLE_RENTBIKE=true
WORKER_ENABLE_DELIVERY=true
WORKER_HEARTBEAT_MS=60000
