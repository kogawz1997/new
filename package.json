{
  "name": "discord",
  "version": "1.0.0",
  "description": "SCUM Discord server bot (economy, shop, tickets, stats)",
  "main": "src/bot.js",
  "scripts": {
    "setup:easy": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-easy.ps1",
    "start": "node src/bot.js",
    "start:bot": "node src/bot.js",
    "start:worker": "node src/worker.js",
    "start:web-standalone": "node apps/web-portal-standalone/server.js",
    "doctor:web-standalone": "node apps/web-portal-standalone/scripts/doctor.js",
    "doctor:web-standalone:prod": "node apps/web-portal-standalone/scripts/doctor.js --production",
    "register-commands": "node src/register-commands.js",
    "watch-scum": "node scum-log-watcher.js",
    "test": "node --test --test-concurrency=1",
    "lint": "node scripts/check-js-syntax.js && node scripts/check-text-encoding.js",
    "check": "npm run lint && npm test",
    "doctor": "node scripts/doctor.js",
    "security:check": "node scripts/security-check.js",
    "security:generate-secrets": "node scripts/generate-secrets.js"
  },
  "keywords": [
    "discord",
    "bot",
    "scum",
    "game-server"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1"
  },
  "overrides": {
    "undici": "^6.23.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
