{
  "name": "scum-th-platform",
  "version": "1.0.0",
  "description": "SCUM TH control plane with Discord bot, admin web, player portal, and delivery runtime",
  "main": "src/bot.js",
  "scripts": {
    "setup:easy": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-easy.ps1",
    "scum:audit": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/scum-instance-audit.ps1",
    "scum:cleanup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/scum-instance-cleanup.ps1",
    "start": "node src/bot.js",
    "start:bot": "node src/bot.js",
    "start:worker": "node src/worker.js",
    "start:scum-agent": "node src/scum-console-agent.js",
    "scum:agent:exec": "node scripts/send-scum-agent-command.js",
    "start:watcher": "node src/services/scumLogWatcherRuntime.js",
    "start:web-standalone": "node apps/web-portal-standalone/server.js",
    "preview:spawn": "node scripts/preview-spawn-command.js",
    "cleanup:test-data": "node scripts/cleanup-test-data.js",
    "shop:canonicalize": "node scripts/canonicalize-shop-items.js",
    "doctor:topology": "node scripts/doctor-topology.js",
    "doctor:topology:prod": "node scripts/doctor-topology.js --production",
    "pm2:start:prod": "pm2 start deploy/pm2.ecosystem.config.cjs --update-env",
    "pm2:reload:prod": "pm2 reload deploy/pm2.ecosystem.config.cjs --update-env",
    "pm2:start:local": "pm2 start deploy/pm2.local.config.cjs --update-env",
    "pm2:start:scum-agent": "pm2 start deploy/pm2.scum-agent.config.cjs --update-env",
    "text:scan": "node scripts/repair-text.js",
    "text:repair": "node scripts/repair-text.js --write",
    "doctor:web-standalone": "node apps/web-portal-standalone/scripts/doctor.js",
    "doctor:web-standalone:prod": "node apps/web-portal-standalone/scripts/doctor.js --production",
    "register-commands": "node src/register-commands.js",
    "watch-scum": "node src/services/scumLogWatcherRuntime.js",
    "test": "node --test --test-concurrency=1",
    "lint": "node scripts/check-js-syntax.js && node scripts/check-text-encoding.js",
    "check": "npm run lint && npm test",
    "ci:verify": "node scripts/run-ci-verification.js",
    "doctor": "node scripts/doctor.js",
    "readiness:full": "node scripts/readiness-gate.js",
    "readiness:prod": "node scripts/readiness-gate.js --production",
    "readiness:prod:audit": "node scripts/readiness-gate.js --production --with-audit",
    "preflight:prod": "node scripts/preflight-prod.js",
    "smoke:postdeploy": "node scripts/post-deploy-smoke.js",
    "smoke:local-ci": "node scripts/run-local-smoke-stack.js",
    "admin:sso:roles": "node scripts/export-admin-discord-roles.js",
    "security:check": "node scripts/security-check.js",
    "security:scan-secrets": "node scripts/secret-scan.js",
    "security:scan-secrets:staged": "node scripts/secret-scan.js --staged",
    "security:generate-secrets": "node scripts/generate-secrets.js",
    "security:generate-admin-2fa": "node scripts/generate-admin-2fa-secret.js",
    "security:scaffold-split-env": "node scripts/scaffold-split-origin-env.js",
    "security:apply-split-env": "node scripts/apply-split-origin-env.js",
    "security:activate-split-env": "node scripts/activate-split-origin-env.js",
    "security:rotate:prod:dry": "node scripts/rotate-production-secrets.js",
    "security:rotate:prod": "node scripts/rotate-production-secrets.js --write",
    "env:preview:development": "node scripts/setup-env-profile.js --profile=development",
    "env:preview:test": "node scripts/setup-env-profile.js --profile=test",
    "env:preview:production": "node scripts/setup-env-profile.js --profile=production",
    "env:prepare:development": "node scripts/setup-env-profile.js --profile=development --write",
    "env:prepare:test": "node scripts/setup-env-profile.js --profile=test --write",
    "env:prepare:production": "node scripts/setup-env-profile.js --profile=production --write",
    "db:generate": "prisma generate",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:deploy:safe": "node scripts/migrate-with-rollback.js",
    "hooks:install": "node scripts/install-git-hooks.js",
    "deploy:oneclick:win": "deploy\\one-click-production.cmd",
    "platform:schema:upgrade": "node scripts/platform-schema-upgrade.js",
    "platform:bootstrap:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/platform-bootstrap.ps1"
  },
  "keywords": [
    "discord",
    "bot",
    "scum",
    "game-server"
  ],
  "author": "Taweporn Chok (kogawz1997) <tawepornchok@gmail.com>",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kogawz1997/Scum-bot-discord-Full-.git"
  },
  "bugs": {
    "url": "https://github.com/kogawz1997/Scum-bot-discord-Full-/issues"
  },
  "homepage": "https://github.com/kogawz1997/Scum-bot-discord-Full-#readme",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "rcon-client": "^4.2.5"
  },
  "overrides": {
    "undici": "^6.23.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
